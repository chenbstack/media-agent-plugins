{
  "fields": [
    {
      "name": "base_url",
      "type": "url",
      "label": "MoviePilot 地址",
      "required": true,
      "placeholder": "https://mp.example.com"
    },
    {
      "name": "bridge_token",
      "type": "password",
      "label": "迁移桥 Token",
      "required": true,
      "secret": true
    },
    {
      "name": "page_limit",
      "type": "number",
      "label": "分页大小",
      "default": 500
    },
    { "name": "include_system_settings", "type": "boolean", "label": "系统设置快照", "default": true },
    { "name": "include_plugin_configs", "type": "boolean", "label": "插件配置快照", "default": true },
    { "name": "include_plugin_data", "type": "boolean", "label": "插件数据快照", "default": true },
    { "name": "include_sites", "type": "boolean", "label": "站点", "default": true },
    { "name": "include_subscriptions", "type": "boolean", "label": "订阅", "default": true },
    { "name": "include_subscribe_history", "type": "boolean", "label": "订阅历史快照", "default": true },
    { "name": "include_transfer_history", "type": "boolean", "label": "整理历史", "default": true }
  ]
}
