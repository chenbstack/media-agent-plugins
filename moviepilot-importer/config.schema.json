{
  "fields": [
    {
      "name": "base_url",
      "type": "url",
      "label": "MoviePilot 地址",
      "required": true,
      "placeholder": "http://192.168.1.10:3000",
      "help": "填写 MoviePilot 首页地址，不需要附加 /api/v1"
    },
    {
      "name": "username",
      "type": "string",
      "label": "MoviePilot 用户名",
      "required": true,
      "placeholder": "admin"
    },
    {
      "name": "password",
      "type": "password",
      "label": "MoviePilot 密码",
      "required": true,
      "secret": true
    },
    {
      "name": "page_limit",
      "type": "number",
      "label": "分页大小",
      "default": 500
    },
    { "name": "include_sites", "type": "boolean", "label": "站点", "default": true },
    { "name": "include_subscriptions", "type": "boolean", "label": "订阅", "default": true },
    { "name": "include_subscribe_history", "type": "boolean", "label": "订阅历史快照", "default": true },
    { "name": "include_transfer_history", "type": "boolean", "label": "整理历史", "default": true }
  ]
}
